# ============================================
# VAPI (Keep existing)
# ============================================
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=41aa45d5-6d3a-4d23-a70e-9d66a7c8868d
VAPI_PRIVATE_KEY=your_vapi_private_key
VAPI_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# SUPABASE (Free tier - 500MB database)
# https://supabase.com → New Project
# ============================================
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# NEXTAUTH.JS (Free - open source)
# Generate secret: openssl rand -base64 32
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_32_chars

# Google OAuth (Free)
# https://console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# RESEND EMAIL (Free - 3000 emails/month)
# https://resend.com → API Keys
# ============================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=recruitment@yourdomain.com

# ============================================
# UPSTASH REDIS (Free - rate limiting)
# https://upstash.com → Create Database
# ============================================
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ============================================
# GOOGLE CALENDAR API (Free)
# https://console.cloud.google.com → Calendar API
# ============================================
GOOGLE_CALENDAR_CLIENT_ID=your_calendar_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_calendar_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/calendar/callback
GOOGLE_CALENDAR_REFRESH_TOKEN=your_refresh_token
GOOGLE_CALENDAR_ID=primary

# ============================================
# SENTRY (Free - 5000 errors/month)
# https://sentry.io → New Project → Next.js
# ============================================
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Zensar AI Recruitment Bot"
NODE_ENV=development
