// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTHENTICATION MODELS (NextAuth.js required)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(RECRUITER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  appointments Appointment[] @relation("RecruiterAppointments")

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  ADMIN
  RECRUITER
  VIEWER
}

// ============================================
// CORE BUSINESS MODELS
// ============================================

model Candidate {
  id           String          @id @default(cuid())
  name         String
  email        String?         @unique
  phone        String?
  jobRole      String?
  experience   String?
  status       CandidateStatus @default(NEW)
  notes        String?         @db.Text
  source       String?         @default("voice-bot")
  consentGiven Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  calls        Call[]
  appointments Appointment[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum CandidateStatus {
  NEW
  CONTACTED
  SCREENING
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFER_SENT
  HIRED
  REJECTED
  WITHDRAWN
}

model Call {
  id            String     @id @default(cuid())
  vapiCallId    String     @unique
  candidateId   String?
  duration      Int?
  status        CallStatus @default(INITIATED)
  transcript    Json?
  summary       String?    @db.Text
  extractedData Json?
  sentiment     String?
  recordingUrl  String?
  startedAt     DateTime   @default(now())
  endedAt       DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  candidate Candidate? @relation(fields: [candidateId], references: [id])

  @@index([vapiCallId])
  @@index([candidateId])
  @@index([status])
  @@index([startedAt])
}

enum CallStatus {
  INITIATED
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
}

model Appointment {
  id               String            @id @default(cuid())
  candidateId      String
  recruiterId      String?
  googleEventId    String?           @unique
  googleMeetLink   String?
  title            String            @default("Interview - Zensar Technologies")
  scheduledAt      DateTime
  durationMinutes  Int               @default(60)
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?           @db.Text
  reminderSent     Boolean           @default(false)
  confirmationSent Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id])
  recruiter User?     @relation("RecruiterAppointments", fields: [recruiterId], references: [id])

  @@index([candidateId])
  @@index([scheduledAt])
  @@index([status])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
}

model Analytics {
  id                  String   @id @default(cuid())
  date                DateTime @unique @db.Date
  callCount           Int      @default(0)
  avgDuration         Float    @default(0)
  newCandidates       Int      @default(0)
  scheduledInterviews Int      @default(0)
  completedInterviews Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([date])
}
